{
  "name": "health-io",
  "version": "1.0.0",
  "private": true,
  "description": "AI health consultation platform monorepo",
  "main": "dist/server.js",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build:backend && npm run build --workspace frontend",
    "build:backend": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:frontend": "npm run lint --workspace frontend",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express-rate-limit": "^8.1.0",
    "express": "^5.2.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "razorpay": "^2.9.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.46.1"
  }
}
